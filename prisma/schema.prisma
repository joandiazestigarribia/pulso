generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BattleState {
  PENDING
  COMPLETED
}

enum MergeAuditStatus {
  MERGED
  NOOP
  INVALID_SOURCE
}

enum CatalogCurationRuleType {
  ARTIST
}

enum ConversionEventName {
  battle_started
  vote_submitted
  profile_teaser_viewed
  profile_unlock_reached
  auth_prompt_shown
  auth_completed
  merge_completed
  export_started
  export_completed
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id               String            @id
  email            String?           @unique
  passwordHash     String?
  role             UserRole          @default(USER)
  profileCompleted Boolean           @default(false)
  battles          Battle[]
  musicProfile     MusicProfile?
  mergeAudits      MergeAudit[]
  conversionEvents ConversionEvent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Track {
  id           String   @id
  catalogBucket String   @default("general")
  name         String
  artist       String
  albumImage   String
  previewUrl   String?
  previewSource String?
  previewCheckedAt DateTime?
  eloScore     Int      @default(1500)
  battlesCount Int      @default(0)
  bpm          Int
  duration     String
  genre        String
  year         Int
  energy       Float?
  valence      Float?
  danceability Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  battlesAsA Battle[] @relation("BattleTrackA")
  battlesAsB Battle[] @relation("BattleTrackB")
}

model CatalogCurationRule {
  id        String                  @id @default(cuid())
  type      CatalogCurationRuleType
  pattern   String
  isActive  Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([type, isActive])
  @@unique([type, pattern])
}

model Battle {
  id               String      @id @default(cuid())
  userId           String
  trackAId         String
  trackBId         String
  winnerId         String?
  loserId          String?
  winnerEloChange  Int?
  loserEloChange   Int?
  status           BattleState @default(PENDING)
  createdAt        DateTime    @default(now())
  completedAt      DateTime?
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackA           Track       @relation("BattleTrackA", fields: [trackAId], references: [id], onDelete: Restrict)
  trackB           Track       @relation("BattleTrackB", fields: [trackBId], references: [id], onDelete: Restrict)

  @@index([userId, status, createdAt])
  @@index([trackAId, createdAt])
  @@index([trackBId, createdAt])
  @@index([status, createdAt])
}

model MusicProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  summary             String?
  dominantGenre       String?
  genreVarietyScore   Float?
  averageEnergy       Float?
  averageValence      Float?
  averageDanceability Float?
  decadeDistribution  Json?
  generatedFromVotes  Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MergeAudit {
  id                String           @id @default(cuid())
  sourceAnonymousId String?
  targetUserId      String
  movedBattles      Int              @default(0)
  status            MergeAuditStatus
  createdAt         DateTime         @default(now())
  user              User             @relation(fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
  @@index([sourceAnonymousId, createdAt])
}

model ConversionEvent {
  id          String              @id @default(cuid())
  eventName   ConversionEventName
  userId      String?
  anonymousId String?
  battleId    String?
  variant     String?
  metadata    Json?
  createdAt   DateTime            @default(now())
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@index([anonymousId, createdAt])
}
